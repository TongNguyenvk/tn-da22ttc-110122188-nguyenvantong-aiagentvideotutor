# ============================================================
# WebReel AI Agent - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- AI / LLM ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# --- TTS (Text-to-Speech) ---
# FPT.AI API key (free tier: 20,000 chars/day)
FPT_API_KEY=your_fpt_api_key_here
# Edge TTS does not need a key (free, uses Microsoft Edge voices)

# --- Chrome CDP ---
# Local development:
CHROME_CDP_URL=http://localhost:9222
# Docker production:
# CHROME_CDP_URL=http://chrome:9222

# --- Redis (production only) ---
# Password (MUST match docker-compose.prod.yml --requirepass)
REDIS_PASSWORD=webreel_secret_2026

# Inside Docker (containers talk to each other):
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# OS Worker on Windows (connect via SSH tunnel):
#   1. Open tunnel: ssh -N -L 6379:localhost:6379 user@vps-ip
#   2. Then use: REDIS_URL=redis://:webreel_secret_2026@localhost:6379/0
# NEVER expose Redis port 6379 to public internet!

# --- MongoDB (production database) ---
# MongoDB connection string
MONGO_URL=mongodb://webreel:secure_password_here@mongodb:27017
MONGO_DB=webreel

# For local development:
# MONGO_URL=mongodb://localhost:27017
# MONGO_DB=webreel_dev

# For MongoDB Atlas (cloud):
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGO_DB=webreel

# --- Cloudflare R2 (video storage) - OPTIONAL, chưa cấu hình ---
# Bỏ trống nếu chưa dùng, videos sẽ lưu local filesystem
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2_ACCESS_KEY=your_r2_access_key_here
# R2_SECRET_KEY=your_r2_secret_key_here
# R2_BUCKET=webreel-videos
# R2_PUBLIC_URL=https://cdn.example.com

# --- File Storage (Phase 2 - Office Viewer) ---
# Cloudflare R2 or AWS S3 for PPTX upload
# S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET=webreel-uploads
# S3_PUBLIC_URL=https://pub-xxx.r2.dev

# --- Output ---
OUTPUT_DIR=output
FFMPEG_PATH=ffmpeg

# --- Security ---
# SECRET_KEY for signed URLs (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# SECRET_KEY=your_secret_key_here

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
# Type: Web application
# Authorized JavaScript origins: http://localhost:5173 (dev), https://yourdomain.com (prod)
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# INTERNAL_API_KEY for OS Worker authentication (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
INTERNAL_API_KEY=your_internal_api_key_here

# --- OS Worker Configuration (Windows machine) ---
# API URL for uploading results (HTTPS recommended)
API_URL=https://your-vps-ip:8000

# Worker settings
WORKER_ID=os-worker-1
WORKER_QUEUE=os-queue
POLL_TIMEOUT=10

# Idle detection (seconds, 0 to disable)
IDLE_THRESHOLD=120

# Upload settings
UPLOAD_ENABLED=true
CLEANUP_AFTER_UPLOAD=true

# SSH Tunnel settings (for secure Redis connection)
USE_SSH_TUNNEL=false
VPS_HOST=your-vps-ip
VPS_USER=your-ssh-username
VPS_SSH_KEY_PATH=~/.ssh/id_rsa
# VPS_PASSWORD=your-ssh-password  # Not recommended, use SSH key instead
LOCAL_REDIS_PORT=6379
REMOTE_REDIS_PORT=6379
TUNNEL_RECONNECT_INTERVAL=30
TUNNEL_HEALTH_CHECK_INTERVAL=60

# Health check settings (for worker monitoring)
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=60
HEARTBEAT_TTL=120

# --- Microsoft Graph API (for OneDrive upload) ---
MS_CLIENT_ID=your_client_id_here
MS_CLIENT_SECRET=your_client_secret_here
MS_TENANT_ID=common
MS_BOT_EMAIL=your_bot_email@outlook.com
